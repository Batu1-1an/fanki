# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Application URLs for metadata and redirect validation
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Google Gemini API Configuration (for Supabase Edge Functions)
# Add this to your Supabase project secrets, not here
# GEMINI_API_KEY=your_gemini_api_key

# Note: The GEMINI_API_KEY should be set as a secret in your Supabase project
# using: supabase secrets set GEMINI_API_KEY=your_actual_api_key
